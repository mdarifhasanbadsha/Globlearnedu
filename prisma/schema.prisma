
generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}
model University {
  id          String @id @default(cuid())
  name        String
  slug        String @unique
  country     String
  description String
}
model Application {
  id           String @id @default(cuid())
  userEmail    String
  universityId String
  status       String @default("submitted")
}
